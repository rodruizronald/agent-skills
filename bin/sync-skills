#!/usr/bin/env bash
set -euo pipefail

REPO_DIR="$(cd "$(dirname "$0")/.." && pwd)"
TARGET_DIRS=("$HOME/.claude" "$HOME/.copilot")

synced=false

for BASE_DIR in "${TARGET_DIRS[@]}"; do
  if [[ -d "$BASE_DIR" ]]; then
    TARGET="$BASE_DIR/skills"
    mkdir -p "$TARGET"
    rsync -av --delete \
      --exclude='.git' \
      --exclude='.gitignore' \
      --exclude='bin' \
      --exclude='.*' \
      "$REPO_DIR/" "$TARGET/"
    echo ""
    echo "Skills synced to $TARGET"
    synced=true
  fi
done

if [[ "$synced" == false ]]; then
  echo "No target directories found. Expected one of: ${TARGET_DIRS[*]}"
  exit 1
fi
